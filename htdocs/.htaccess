# 1. Защита файла с заявками (чтобы никто не украл телефоны клиентов)
<Files "leads.txt">
    Order Allow,Deny
    Deny from all
</Files>

# 2. Установка главной страницы
DirectoryIndex index.html index.php

# 3. Основные правила перенаправления
RewriteEngine On

# --- ПРАВИЛА ДЛЯ УДАЛЕНИЯ СТАРЫХ СТРАНИЦ ---

# Перенаправляем всё из папки /pages/ в корень сайта float-camera.ru
# Это даст Яндексу "основание" для удаления ссылок
RewriteRule ^pages/(.*)$ https://float-camera.ru/$1 [R=301,L]

# Убираем index.html из адреса (склейка дублей для SEO)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
RewriteRule ^index\.html$ https://float-camera.ru/ [R=301,L]

# --- КОНЕЦ НОВЫХ ПРАВИЛ ---

# Переадресация на HTTPS (настройки HTS)
RewriteCond %{HTTP:X-SSL} !^yes$
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 4. Запрет на просмотр папок
Options -Indexes