<div id="modalForm" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <h2 id="modalTitle" style="color:var(--primary); margin-top:0;">Оставить заявку</h2>
        <form action="send.php" method="POST" id="universalForm">
            <input type="hidden" name="form_subject" id="formSubject" value="Заявка с сайта">
            <input type="text" name="website_trap" style="display:none !important;" tabindex="-1">
            <div class="form-group"><input type="text" name="name" placeholder="Ваше имя" required></div>
            <div class="form-group"><input type="tel" name="phone" id="userPhone" placeholder="Ваш телефон"></div>
            <div class="form-group"><input type="email" name="email" id="userEmail" placeholder="Ваш e-mail"></div>
            <div class="form-group"><input type="text" name="company" placeholder="Название организации"></div>
            <div class="form-group"><textarea name="question" placeholder="Ваш вопрос" rows="3"></textarea></div>
            <p style="font-size: 0.8em; color: #666; margin-bottom:15px;">* Укажите телефон или почту для связи.</p>
            
            <div style="font-size:0.8em; color:#777; margin-bottom:15px; display:flex; gap:8px; align-items: flex-start; text-align: left;">
                <input type="checkbox" name="agree" id="modal_agree" required style="width:auto; margin: 3px 0 0 0; cursor: pointer;">
                <label for="modal_agree" style="cursor: pointer;">
                    Я согласен с <a href="privacy.html" target="_blank" style="color:#777; text-decoration: underline;">политикой конфиденциальности</a>
                </label>
            </div>
            
            <button type="submit" class="submit-btn">ОТПРАВИТЬ ЗАЯВКУ</button>
        </form>
    </div>
</div>

<script>
function openModal(subject) { document.getElementById('modalForm').style.display = 'block'; document.getElementById('formSubject').value = subject; document.getElementById('modalTitle').innerText = subject; }
function closeModal() { document.getElementById('modalForm').style.display = 'none'; }
window.onclick = function(event) { if (event.target == document.getElementById('modalForm')) closeModal(); }
</script>

<script src="assets/js/miracle-redesign.js"></script>
